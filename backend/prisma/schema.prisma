generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  OFFICE_STAFF
  SITE_SUPERVISOR
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum DocumentStatus {
  DRAFT
  PENDING
  FINALIZED
}

enum DocumentType {
  QUOTATION
  INVOICE
  BILL
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role
  siteId       String?  @map("site_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  @@map("users")
}

model Client {
  id            String   @id @default(cuid())
  companyName   String   @map("company_name")
  contactPerson String   @map("contact_person")
  mobile        String
  email         String?
  gstNumber     String?  @map("gst_number")
  address       String   @db.Text
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sites       Site[]
  quotations  Quotation[]
  invoices    Invoice[]

  @@index([companyName])
  @@map("clients")
}

model Site {
  id             String   @id @default(cuid())
  name           String
  clientId       String   @map("client_id")
  address        String   @db.Text
  supervisorName String   @map("supervisor_name")
  contactNumber  String   @map("contact_number")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  employees   Employee[]
  attendances Attendance[]
  quotations  Quotation[]
  invoices    Invoice[]
  users       User[]

  @@index([clientId])
  @@map("sites")
}

model Employee {
  id           String   @id @default(cuid())
  employeeCode String   @unique @map("employee_code")
  name         String
  mobile       String
  aadhaar      String?
  designation  String
  salary       Decimal  @db.Decimal(12, 2)
  joiningDate  DateTime @map("joining_date") @db.Date
  siteId       String   @map("site_id")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  site        Site         @relation(fields: [siteId], references: [id], onDelete: Restrict)
  attendances Attendance[]

  @@index([siteId])
  @@index([name])
  @@map("employees")
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String           @map("employee_id")
  siteId     String           @map("site_id")
  date       DateTime         @db.Date
  status     AttendanceStatus
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  site     Site     @relation(fields: [siteId], references: [id], onDelete: Restrict)

  @@unique([employeeId, date])
  @@index([siteId, date])
  @@index([date])
  @@map("attendances")
}

model Quotation {
  id              String         @id @default(cuid())
  quotationNumber String         @unique @map("quotation_number")
  date            DateTime       @db.Date
  clientId        String         @map("client_id")
  siteId          String         @map("site_id")
  terms           String?        @db.Text
  status          DocumentStatus @default(DRAFT)
  subtotal        Decimal        @db.Decimal(12, 2)
  gstPercent      Decimal        @map("gst_percent") @db.Decimal(5, 2)
  gstAmount       Decimal        @map("gst_amount") @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  client Client          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site   Site            @relation(fields: [siteId], references: [id], onDelete: Restrict)
  items  QuotationItem[]

  @@index([clientId])
  @@index([status])
  @@map("quotations")
}

model QuotationItem {
  id                 String  @id @default(cuid())
  quotationId        String  @map("quotation_id")
  serviceDescription String  @map("service_description") @db.Text
  numberOfEmployees  Int     @map("number_of_employees")
  duty               String? @default("8 Hrs")
  rate               Decimal @db.Decimal(12, 2)
  amount             Decimal @db.Decimal(12, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

model Invoice {
  id            String         @id @default(cuid())
  invoiceNumber String         @unique @map("invoice_number")
  date          DateTime       @db.Date
  clientId      String         @map("client_id")
  siteId        String         @map("site_id")
  periodFrom    DateTime       @map("period_from") @db.Date
  periodTo      DateTime       @map("period_to") @db.Date
  status        DocumentStatus @default(DRAFT)
  subtotal      Decimal        @db.Decimal(12, 2)
  gstPercent    Decimal        @map("gst_percent") @db.Decimal(5, 2)
  gstAmount     Decimal        @map("gst_amount") @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  client Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  site   Site          @relation(fields: [siteId], references: [id], onDelete: Restrict)
  items  InvoiceItem[]
  bills  Bill[]

  @@index([clientId])
  @@index([status])
  @@map("invoices")
}

model InvoiceItem {
  id             String   @id @default(cuid())
  invoiceId      String   @map("invoice_id")
  serviceDetails String   @map("service_details") @db.Text
  quantity       Decimal  @db.Decimal(12, 2)
  rate           Decimal  @db.Decimal(12, 2)
  mandays        Decimal? @db.Decimal(12, 2)
  actualMandays  Decimal? @map("actual_mandays") @db.Decimal(12, 2)
  amount         Decimal  @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model Bill {
  id              String   @id @default(cuid())
  billNumber      String   @unique @map("bill_number")
  invoiceId       String   @map("invoice_id")
  billingMonth    String   @map("billing_month")
  attendanceYear  Int      @map("attendance_year")
  attendanceMonth Int      @map("attendance_month")
  totalEmployees  Int      @map("total_employees")
  amount          Decimal  @db.Decimal(12, 2)
  gstPercent      Decimal  @map("gst_percent") @db.Decimal(5, 2)
  gstAmount       Decimal  @map("gst_amount") @db.Decimal(12, 2)
  grandTotal      Decimal  @map("grand_total") @db.Decimal(12, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([billingMonth])
  @@map("bills")
}

model DocumentSequence {
  id           String       @id @default(cuid())
  documentType DocumentType @unique @map("document_type")
  year         Int
  lastNumber   Int          @default(0) @map("last_number")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("document_sequences")
}
